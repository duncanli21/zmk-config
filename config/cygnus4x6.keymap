#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    // Define a default keymap here.
    // See https://zmk.dev/docs/development/hardware-integration/new-shield#default-keymap.

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            //-----------------------------------------------------------------------------------------------
            //  ESC |   1   |   2   |   3   |   4   |   5   |   6   |   7   |   8   |   9   |   0   |   -   |
            //  TAB |   Q   |   W   |   E   |   R   |   T   |   Y   |   U   |   I   |   O   |   P   |   [   |
            // SHIFT|   A   |   S   |   D   |   F   |   G   |   H   |   J   |   K   |   L   |   ;   |   '   |
            //  CTL |   Z   |   X   |   C   |   V   |   B   |   N   |   M   |   ,   |   .   |   /   | SHIFT |
            //                      | SUPER | SYMBL | ENTER |  ALT  | SPACE | BKSPCE|

            bindings = <
&kp EQUAL  &kp N1  &kp N2  &kp N3  &kp N4  &kp N5  &kp N6  &kp N7  &kp N8  &kp N9  &kp N0  &kp MINUS  &kp TAB  &kp Q  &kp W  &kp F  &kp P  &kp G  &kp J  &kp L  &kp U  &kp Y  &kp SEMICOLON  &kp NON_US_BACKSLASH  &kp ESCAPE  &kp A  &kp R  &kp S  &kp T  &kp D  &kp H  &kp N  &kp E  &kp I  &kp O  &kp SINGLE_QUOTE  &kp LCTRL  &kp Z  &kp X  &kp C  &kp V  &kp B  &kp K  &kp M  &kp COMMA  &kp DOT  &kp SLASH  &kp LGUI  &mo 2  &kp BACKSPACE  &kp LEFT_SHIFT  &kp ENTER  &kp SPACE  &mo 1
            >;
        };

        // This is my personal symbol layer for a german QWERTZ layout

        symbols_layer {
            //-----------------------------------------------------------------------------------------------
            //   F1 |   F2  |   F3  |   F4  |   F5  |   F6  |   F7  |   F8  |  F9   |  F10  |  F11  |  F12  |
            // BT 0 |  BT 1 |  HOME |   UP  |  END  | PG_UP |  +/*  |   {   |   }   |       |       | BTCLR |
            //      |  BT 2 |  LEFT |  DOWN | RIGHT | PG_DN |  #/'  |   (   |   )   |       |       |       |
            //      |   |   |       |   <   |   >   |       |  ^/°   |   [   |   ]   |       |       |STIOULK|
            //                      |       |       |       |  RALT |       |  DEL  |

            bindings = <
&kp F1  &kp F2  &kp F3  &kp F4  &kp F5  &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &kp F11  &kp F12  &bt BT_SEL 0  &kp GRAVE  &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &trans  &trans  &trans  &trans  &bt BT_CLR  &bt BT_SEL 1  &kp GRAVE  &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6  &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp LS(N8)  &kp LS(N9)  &trans  &trans  &trans  &bt BT_SEL 2  &kp RA(KP_NUMBER_0)  &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp LS(KP_NUMBER_3)  &kp LEFT_BRACE  &kp RIGHT_BRACE  &kp RA(N8)  &kp RA(N9)  &trans  &trans  &studio_unlock  &kp LEFT_ALT  &trans  &trans  &trans  &trans  &trans
            >;
        };

        layer_2 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &kp DEL  &trans  &trans  &trans  &trans  &trans  &trans  &kp DOWN  &kp RIGHT  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &kp LEFT  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &kp UP_ARROW  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
